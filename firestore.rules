rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn(); // Allow any signed in user for now
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidRestaurant(data) {
      return data.keys().hasAll(['id', 'name', 'city', 'rating', 'open', 'close', 'img']) &&
             data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.city in ['hanoi', 'hcm', 'hue', 'danang', 'dalat'] &&
             data.rating is number && data.rating >= 0 && data.rating <= 10 &&
             data.open is string && data.open.matches('^[0-9]{2}:[0-9]{2}$') &&
             data.close is string && data.close.matches('^[0-9]{2}:[0-9]{2}$') &&
             data.img is string && data.img.size() <= 1000 &&
             (data.get('address', '') is string && data.get('address', '').size() <= 500) &&
             (data.get('info', '') is string && data.get('info', '').size() <= 2000) &&
             (data.get('imgPath', '') is string && data.get('imgPath', '').size() <= 1000);
    }

    // --- Collection Routes ---

    match /restaurants/{restaurantId} {
      allow read: if true; // Publicly accessible for reading
      
      allow create: if isAdmin() &&
                       isValidId(restaurantId) &&
                       isValidRestaurant(incoming()) &&
                       incoming().id == restaurantId &&
                       incoming().createdAt == request.time &&
                       incoming().createdBy == request.auth.token.email;
                       
      allow update: if isAdmin() &&
                       isValidId(restaurantId) &&
                       isValidRestaurant(incoming()) &&
                       incoming().id == existing().id &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().createdBy == existing().createdBy &&
                       incoming().updatedAt == request.time &&
                       incoming().updatedBy == request.auth.token.email &&
                       // Action: General Update (All mutable fields)
                       incoming().diff(existing()).affectedKeys().hasOnly([
                         'name', 'city', 'rating', 'address', 'info', 
                         'open', 'close', 'img', 'imgPath', 
                         'updatedAt', 'updatedBy'
                       ]);
                       
      allow delete: if isAdmin() && isValidId(restaurantId);
    }
  }
}
